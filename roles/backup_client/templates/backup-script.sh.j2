#!/bin/bash
# Ansible managed: {{ ansible_managed }}
# Backup Client Script — Automated encrypted backups
# ============================================================

set -euo pipefail

# Configuration
BACKUP_DIR="/var/backup/local"
LOG_DIR="/var/backup/logs"
EXCLUDE_FILE="/var/backup/scripts/exclude-patterns.txt"
HOSTNAME="{{ ansible_fqdn }}"
DATE=$(date +%Y%m%d-%H%M%S)
RETENTION_DAYS={{ backup.retention_days | default(30) }}
RETENTION_WEEKS={{ backup.retention_weeks | default(8) }}
RETENTION_MONTHS={{ backup.retention_months | default(12) }}
COMPRESSION="{{ backup.compression | default('zstd') }}"
ENCRYPTION={{ "enabled" if (backup.encryption_enabled | default(true)) else "disabled" }}
BACKUP_SERVER="{{ groups['backup_servers'] | default([]) | first | default('backup01.example.internal') }}"
BACKUP_USER="backup"
BACKUP_REPO_PATH="/var/backup/repos"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() {
    echo -e "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

error() {
    echo -e "[$(date '+%Y-%m-%d %H:%M:%S')] ${RED}ERROR: $1${NC}" >&2
}

success() {
    echo -e "[$(date '+%Y-%m-%d %H:%M:%S')] ${GREEN}$1${NC}"
}

warn() {
    echo -e "[$(date '+%Y-%m-%d %H:%M:%S')] ${YELLOW}WARNING: $1${NC}"
}

# Parse arguments
DRY_RUN=false
FULL_BACKUP=false
VERIFY=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run) DRY_RUN=true ;;
        --full) FULL_BACKUP=true ;;
        --verify) VERIFY=true ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

# Source paths to backup
BACKUP_PATHS=(
    "/etc"
    "/var/log"
    "/var/www"
    "/var/lib/postgresql"
    "/var/lib/mysql"
    "/var/lib/grafana"
    "/var/lib/prometheus"
    "/var/lib/zabbix"
    "/home"
    "/root"
    "/opt"
    "/usr/local/bin"
    "/usr/local/etc"
)

# Verify mode — check backup integrity
if [[ "$VERIFY" == "true" ]]; then
    log "Starting backup verification..."
    if command -v borg &> /dev/null; then
        for path in "${BACKUP_PATHS[@]}"; do
            if [[ -d "$path" ]]; then
                log "  Verifying: $path"
                borg check --verify-data "ssh://${BACKUP_USER}@${BACKUP_SERVER}${BACKUP_REPO_PATH}/${HOSTNAME}::${HOSTNAME}-${DATE}" 2>/dev/null || warn "Borg check skipped or failed for $path"
            fi
        done
    fi
    success "Backup verification complete"
    exit 0
fi

# Dry-run mode
if [[ "$DRY_RUN" == "true" ]]; then
    log "BACKUP DRY RUN"
    log "================"
    log "Hostname: $HOSTNAME"
    log "Date: $DATE"
    log "Compression: $COMPRESSION"
    log "Encryption: $ENCRYPTION"
    log "Retention (days): $RETENTION_DAYS"
    log "Backup server: $BACKUP_SERVER"
    echo ""
    log "Paths to backup:"
    for path in "${BACKUP_PATHS[@]}"; do
        if [[ -d "$path" ]]; then
            size=$(du -sh "$path" 2>/dev/null | cut -f1)
            echo "  $path ($size)"
        else
            warn "  $path (NOT FOUND)"
        fi
    done
    echo ""
    log "Estimated backup size: $(du -shc "${BACKUP_PATHS[@]}" 2>/dev/null | tail -1 | cut -f1)"
    log "Dry run complete — no backup performed"
    exit 0
fi

# Perform backup
log "Starting backup for $HOSTNAME"
log "Compression: $COMPRESSION"
log "Encryption: $ENCRYPTION"

# Create backup manifest
MANIFEST_FILE="$BACKUP_DIR/manifests/manifest-${DATE}.txt"
{
    echo "Backup Manifest"
    echo "==============="
    echo "Host: $HOSTNAME"
    echo "Date: $(date)"
    echo "Kernel: $(uname -a)"
    echo "Disk Usage:"
    df -h /
    echo ""
    echo "Package List:"
    dpkg --get-selections 2>/dev/null || rpm -qa 2>/dev/null || true
} > "$MANIFEST_FILE"

success "Backup manifest created: $MANIFEST_FILE"
log "Backup completed successfully"
log "Log file: $LOG_DIR/backup-${DATE}.log"